{
  "name": "gaokao-pro",
  "version": "0.2.0",
  "description": "中国高考志愿规划 CLI · 用 Claude Code / Codex / Cursor 帮你查招生数据、出冲稳保。v0.2.0 加入 34 省 × 3 年特殊招生(艺术/体育/强基/综评/民族/港澳台)。",
  "type": "module",
  "bin": {
    "gaokao-pro": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "probe": "tsx src/probe.ts",
    "test": "tsx test/smoke.ts",
    "test:special": "tsx test/special-admissions.smoke.ts",
    "test:validate": "tsx test/special-admissions.validate.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gaokao",
    "china",
    "college",
    "admission",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
